# Copy this file to `.env` and fill in your values, or export these variables
# in your shell. Do NOT commit your real .env.

# Your Anthropic API key - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Absolute path to the `headless` folder inside your GAMA installation
# (the folder that contains gama-headless.bat / gama-headless.sh).
#
# Windows example:
#   GAMA_HEADLESS_DIR=C:\Users\<you>\AppData\Local\Programs\Gama\headless
# macOS example (app bundle):
#   GAMA_HEADLESS_DIR=/Applications/Gama.app/Contents/headless
GAMA_HEADLESS_DIR=
